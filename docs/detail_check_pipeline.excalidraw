   "versionNonce": 150267606,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1752000000000,
   "link": null,
   "locked": false,
   "text": "big single-Einsum candidates can look cheap\nbut hang 15+ min per inference (contraction\nblowup). Time one session.run() directly \u2014\ndon't trust param count alone.",
   "fontSize": 13.5,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "baseline": 68.9,
