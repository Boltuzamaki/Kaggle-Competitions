   "isDeleted": false,
   "boundElements": null,
   "updated": 1752000000000,
   "link": null,
   "locked": false,
   "text": "run on onnxruntime==1.24.4 (venv_scorer).\nCatches missing kernels invisible on newer\nlocal runtime, e.g. TopK on uint8/int8.",
