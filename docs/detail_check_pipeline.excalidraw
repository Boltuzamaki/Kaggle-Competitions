   "boundElements": null,
   "updated": 1752000000000,
   "link": null,
   "locked": false,
   "text": "onnx.checker crash != real failure. Cost is\n\"unmeasurable\" locally but real grader may\nstill score it fine. Needs isolated submission.\n(see note * at bottom)",
